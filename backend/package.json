{
  "name": "shule360-backend",
  "version": "2.1.0",
  "description": "Shule360 REST API — Node.js + Express + PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "dev":         "nodemon src/server.js",
    "start":       "node src/server.js",
    "migrate":     "node src/config/migrate.js",
    "migrate:new": "node src/config/migrate_new_tables.js",
    "seed":        "node src/config/seed.js"
  },
  "dependencies": {
    "axios":                  "^1.6.2",
    "bcryptjs":               "^2.4.3",
    "cors":                   "^2.8.5",
    "dotenv":                 "^16.3.1",
    "express":                "^4.18.2",
    "express-rate-limit":     "^7.1.5",
    "express-validator":      "^7.0.1",
    "helmet":                 "^7.1.0",
    "jsonwebtoken":           "^9.0.2",
    "knex":                   "^3.1.0",
    "morgan":                 "^1.10.0",
    "pg":                     "^8.11.3",
    "redis":                  "^4.6.10",
    "uuid":                   "^9.0.1",
    "winston":                "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
